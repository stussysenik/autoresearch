{
  "name": "design-constraint-engine",
  "version": "1.0.0",
  "type": "module",
  "description": "Reverse-engineer visual designs into composable Playwright test assertions across 16 CSS/DOM dimensions",
  "scripts": {
    "fetch": "bun run src/fetch_data.ts",
    "run": "bun run src/run_experiment.ts",
    "analyze": "bun run src/analyze_results.ts",
    "experiment": "bun run src/fetch_data.ts && bun run src/run_experiment.ts && bun run src/analyze_results.ts",
    "test": "bunx playwright test",
    "test:generated": "bunx playwright test tests/generated/"
  },
  "dependencies": {
    "openai": "^4.73.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.10.0",
    "@types/pngjs": "^6.0.5",
    "bun-types": "^1.3.10",
    "typescript": "^5.3.0"
  }
}
